{
  "name": "mpg-docs",
  "version": "1.0.0",
  "type": "module",
  "author": "pafnuty",
  "engines": {
    "node": ">=v20.10.0",
    "pnpm": ">=9.14.4"
  },
  "main": "build/index.html",
  "scripts": {
    "work": "vitepress dev src",
    "work:debug": "DEBUG=true npm run build && npm run preview",
    "build": "vitepress build src",
    "preview": "vitepress preview src",
    "lint:all": "npm run lint:md && npm run lint:scripts && npm run lint:types",
    "fix:all": "npm run fix:md && npm run fix:scripts",
    "lint:scripts": "eslint --config ./eslint.config.js --cache",
    "fix:scripts": "npm run lint:scripts --fix",
    "lint:md": "prettier {./src/**/*,README}.md --check",
    "fix:md": "prettier {./src/**/*,README}.md --write --log-level warn",
    "lint:types": "tsc -p ./tsconfig.json --noEmit",
    "test": "exit 0",
    "test:coverage": "exit 0"
  },
  "dependencies": {
    "@shikijs/vitepress-twoslash": "^1.24.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.0.2",
    "vitepress": "^1.5.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@eslint/compat": "^1.2.4",
    "@eslint/js": "^9.16.0",
    "@evilmartians/lefthook": "^1.8.5",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@stylistic/eslint-plugin": "^2.11.0",
    "@vue/compiler-sfc": "^3.5.13",
    "commitlint-plugin-regex-match": "^1.2.4",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.17.0"
  }
}
