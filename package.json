{
  "name": "mpg-docs",
  "version": "1.0.0",
  "type": "module",
  "author": "pafnuty",
  "engines": {
    "node": ">=v20.10.0",
    "pnpm": ">=9.14.4"
  },
  "main": "build/index.html",
  "scripts": {
    "work": "vitepress dev src",
    "work:debug": "DEBUG=true npm run build && npm run preview",
    "build": "vitepress build src",
    "preview": "vitepress preview src",
    "lint:all": "npm run lint:md && npm run lint:scripts && npm run lint:types",
    "fix:all": "npm run fix:md && npm run fix:scripts",
    "lint:scripts": "eslint --config ./eslint.config.js --cache",
    "fix:scripts": "npm run lint:scripts --fix",
    "lint:md": "prettier {./src/**/*,README}.md --check",
    "fix:md": "prettier {./src/**/*,README}.md --write --log-level warn",
    "lint:types": "tsc -p ./tsconfig.json --noEmit",
    "test": "exit 0",
    "test:coverage": "exit 0"
  },
  "dependencies": {
    "@shikijs/vitepress-twoslash": "^1.29.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.2.0",
    "vitepress": "^1.6.3",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.7",
    "@eslint/js": "^9.21.0",
    "@evilmartians/lefthook": "^1.11.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/node": "^22.13.5",
    "@vue/compiler-sfc": "^3.5.13",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  }
}
